{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Debug All Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Python: Debug Current File",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "FastAPI: Run App",
            "type": "debugpy",
            "request": "launch",
            "module": "app.main",
            "jinja": true,
            "justMyCode": true,
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Sidecar: Run",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/sidecar.py",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
