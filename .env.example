# ─── Cloud API Keys (Runway Dashboard) ───────────────────────
# Get keys from these services and paste them below. 
# Do not commit real keys!

# GitHub Copilot: https://github.com/settings/tokens
GITHUB_TOKEN=github_pat_...

# zAI API (Balance) & zAI Plan (Quota): https://api.z.ai
# Both collectors use the same key
ZAI_API_KEY=sk-zai-...

# Kimi API (Balance): https://api.moonshot.cn
KIMI_API_KEY=sk-proj-...

# Kimi Coding (IDE Quotas): https://www.kimi.com/code
# Get from browser cookie 'kimi-auth' or set manually:
KIMI_AUTH_TOKEN=eyJhbG...

# ─── OAuth Credentials (Optional) ──────────────────────────────
# These are only needed if you want to use the Gemini OAuth flow.
# Otherwise, the app will fall back to local logs.

# Google OAuth (Gemini): https://console.developers.google.com
GEMINI_OAUTH_CLIENT_ID=your_client_id_here
GEMINI_OAUTH_CLIENT_SECRET=your_client_secret_here

# ─── OpenCode Configuration ───────────────────────────────────
# OpenCode uses Chrome cookies to fetch usage from opencode.ai web API.
# Make sure you're logged into opencode.ai in Chrome for automatic detection.
# 
# For multi-host setups, run the sidecar script on each machine:
#   python3 scripts/sidecar.py --provider opencode --api-url http://runway-primary:8765
#
# Disable local collector when running in Docker:
OPENCODE_LOCAL_COLLECTOR_ENABLED=true

# Optional: Force specific workspace ID (auto-detected from Chrome if not set)
# OPENCODE_WORKSPACE_ID=wrk_xxx

# ─── Sidecar Ingestion API ────────────────────────────────────
# API key for external metrics (sidecar scripts on other hosts).
# Use this key when running scripts/sidecar.py on other machines.
INGEST_API_KEY=sidecar-default-secret
