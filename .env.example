# ─── Cloud API Keys ──────────────────────────────────────────
OPENCODE_GO_API_KEY=sk-opencode-go-...
GITHUB_TOKEN=ghp_...
ZAI_API_KEY=sk-zai-...
KIMI_API_KEY=sk-moonshot-...

# ─── Local File Paths (override defaults if non-standard) ────
# Claude Pro: sessions in ~/.claude/projects/**/*.jsonl
# CLAUDE_PROJECTS_DIR=~/.claude/projects

# Gemini CLI: sessions in ~/.gemini/tmp/*/chats/session-*.json
# GEMINI_TMP_DIR=~/.gemini/tmp

# OpenCode TUI: SQLite at ~/.local/share/opencode/opencode.db
# OPENCODE_TUI_DB=~/.local/share/opencode/opencode.db

# ─── Thresholds (optional tuning) ────────────────────────────
# CLAUDE_5H_TOKEN_LIMIT=2000000
# KIMI_WARNING_BALANCE=10.0
# KIMI_CRITICAL_BALANCE=2.0
