# ─── Cloud API Keys (Runway Dashboard) ───────────────────────
# Get keys from these services and paste them below. 
# Do not commit real keys!

# OpenCode Go: https://opencode.ai
OPENCODE_GO_API_KEY=sk-opencode-go-...

# GitHub Copilot: https://github.com/settings/tokens
GITHUB_TOKEN=github_pat_...

# zAI (GLM Coding): https://api.z.ai
ZAI_API_KEY=sk-zai-...

# Kimi K2.5: https://api.moonshot.cn
KIMI_API_KEY=sx...

# ─── OAuth Credentials (Optional) ──────────────────────────────
# These are only needed if you want to use the Gemini OAuth flow.
# Otherwise, the app will fall back to local logs.

# Google OAuth (Gemini): https://console.developers.google.com
GEMINI_OAUTH_CLIENT_ID=your_client_id_here
GEMINI_OAUTH_CLIENT_SECRET=your_client_secret_here
